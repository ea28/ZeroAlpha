# Optional local shell helpers.
#
# ZeroAlpha loads runtime settings from TOML config files, not from this file.
# Keep real account numbers and live config in an uncommitted local TOML file.

ZEROALPHA_CONFIG=configs/paper.example.toml

# Model runtime helpers consumed by src/zeroalpha/models/ensemble.py
ZEROALPHA_MODEL_N_JOBS=1
ZEROALPHA_USE_GPU=false
ZEROALPHA_GPU_DEVICES=0
ZEROALPHA_XGBOOST_DEVICE=cuda

# Optional convenience values for your shell scripts only.
ZEROALPHA_IBKR_HOST=127.0.0.1
ZEROALPHA_IBKR_PAPER_GATEWAY_PORT=4002
ZEROALPHA_IBKR_PAPER_TWS_PORT=7497
ZEROALPHA_IBKR_LIVE_GATEWAY_PORT=4001
ZEROALPHA_IBKR_LIVE_TWS_PORT=7496
